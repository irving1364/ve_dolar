# Base de datos (Vercel Postgres inyecta DATABASE_URL automáticamente en producción)
# Para desarrollo local, usa tu propia instancia PostgreSQL o Vercel Postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vedolar"

# API Key de Deepseek (obtén una en https://platform.deepseek.com)
DEEPSEEK_API_KEY="sk-your-deepseek-api-key"
