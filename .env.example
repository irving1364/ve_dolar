# Base de datos (Vercel Postgres inyecta DATABASE_URL automáticamente en producción)
# Para desarrollo local, usa tu propia instancia PostgreSQL o Vercel Postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vedolar"

# API Key de Groq (gratis en https://console.groq.com)
GROQ_API_KEY="gsk_your-groq-api-key"

# Telegram (opcional) — para notificaciones de trades
# Crea un bot en https://t.me/BotFather y obtén el token
# Envía /start al bot y visita https://api.telegram.org/bot<TOKEN>/getUpdates para obtener tu chat_id
TELEGRAM_BOT_TOKEN="your-bot-token"
TELEGRAM_CHAT_ID="your-chat-id"
