generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Rate {
  id        Int      @id @default(autoincrement())
  source    String
  price     Float
  buyPrice  Float?
  sellPrice Float?
  buyVolume Float?
  sellVolume Float?
  fetchedAt DateTime @default(now())
}
