generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Rate {
  id        Int      @id @default(autoincrement())
  source    String
  price     Float
  buyPrice  Float?
  sellPrice Float?
  buyVolume Float?
  sellVolume Float?
  fetchedAt DateTime @default(now())
}

model Trade {
  id         Int      @id @default(autoincrement())
  type       String
  amount     Float
  price      Float
  status     String   @default("open")
  targetPrice Float?
  closedAt   DateTime?
  profit     Float?
  profitPct  Float?
  notes      String?
  createdAt  DateTime @default(now())
}
